{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
      "target": "ES2022",
      "useDefineForClassFields": true,
      "module": "ES2022",
      "lib": ["ES2022", "DOM", "ES2015"],
      "sourceMap": true,
      "resolveJsonModule": true,
      "noEmit": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noImplicitReturns": true
    },
    "exclude": ["node_modules"]
  }
